{
  "$defs": {
    "ExpenseImportCreate": {
      "description": "Schema for expense import - category_id is optional (will be auto-categorized).",
      "properties": {
        "name": {
          "maxLength": 255,
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "description": {
          "anyOf": [
            {
              "maxLength": 500,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        },
        "amount": {
          "exclusiveMinimum": 0,
          "title": "Amount",
          "type": "number"
        },
        "date": {
          "title": "Date",
          "type": "string"
        },
        "currency": {
          "title": "Currency",
          "type": "string"
        },
        "user_id": {
          "exclusiveMinimum": 0,
          "title": "User Id",
          "type": "integer"
        },
        "source_id": {
          "exclusiveMinimum": 0,
          "title": "Source Id",
          "type": "integer"
        },
        "category_id": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Category Id"
        },
        "account_id": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Account Id"
        }
      },
      "required": [
        "name",
        "amount",
        "date",
        "currency",
        "user_id",
        "source_id"
      ],
      "title": "ExpenseImportCreate",
      "type": "object"
    },
