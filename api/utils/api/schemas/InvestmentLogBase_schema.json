{
  "$defs": {
    "ActionEnum": {
      "enum": [
        "buy",
        "sell",
        "transfer",
        "deposit",
        "withdraw",
        "hold"
      ],
      "title": "ActionEnum",
      "type": "string"
    }
  },
  "description": "Base schema for InvestmentLog aligned with ORM model.",
  "properties": {
    "date": {
      "format": "date",
      "title": "Date",
      "type": "string"
    },
    "current_value": {
      "anyOf": [
        {
          "exclusiveMinimum": 0.0,
          "type": "number"
        },
        {
          "type": "string"
        }
      ],
      "title": "Current Value"
    },
    "price_per_unit": {
      "anyOf": [
        {
          "exclusiveMinimum": 0.0,
          "type": "number"
        },
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Price Per Unit"
    },
    "units_bought": {
      "anyOf": [
        {
          "exclusiveMinimum": 0.0,
          "type": "number"
        },
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Units Bought"
    },
    "action": {
      "$ref": "#/$defs/ActionEnum"
    },
    "note": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Note"
    },
    "investment_id": {
      "exclusiveMinimum": 0,
      "title": "Investment Id",
      "type": "integer"
    }
  },
  "required": [
    "date",
    "current_value",
    "action",
    "investment_id"
  ],
  "title": "InvestmentLogBase",
  "type": "object"
}