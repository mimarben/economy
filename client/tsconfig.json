/* To learn more about Typescript configuration file: https://www.typescriptlang.org/docs/handbook/tsconfig-json.html. */
/* To learn more about Angular compiler options: https://angular.dev/reference/configs/angular-compiler-options. */
{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist/out-tsc",
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "moduleResolution": "bundler",
    "importHelpers": true,
    "target": "ES2022",
    "module": "ES2022",
    "baseUrl": "./",
    "paths": {
      "@app/*": ["src/app/*"],
      
      "@factories/*": ["src/app/core/factories/*"],
      
      "@guards/*": ["src/app/core/guards"],
      
      "@interceptors/*": ["src/app/core/interceptors"],
      
      "@data/*": ["src/app/core/const"],
      
      "@env/*": ["src/environments/*"],
      
      "@services/*": ["src/app/services/*"],
      "@core_services/*": ["src/app/services/core/*"],
      
      "@expenses_services/*": ["src/app/services/expenses/*"],
      "@households_services/*": ["src/app/services/households/*"],
      "@finance_services/*": ["src/app/services/finance/*"],
      "@incomes_services/*": ["src/app/services/incomes/*"],
      "@investments_services/*": ["src/app/services/investments/*"],
      "@savings_services/*": ["src/app/services/savings/*"],
      "@users_services/*": ["src/app/services/users/*"],
      "@auth_services/*":["src/app/services/auth/*"],
      "@import_services/*":["src/app/services/import/*"],

        
      "@features/*":["src/app/features/*"],
      
      "@utils/*": ["src/app/utils/*"],
      
      "@shared/*": ["src/app/shared/components/*"],
      
      "@assets/*": ["src/assets/*"],
      
      "@core/*": ["src/app/core/*"],
      
      "@utils_module/*":["src/app/utils/*"],
      "@core_models/*":["src/app/models/core/*"],
      "@expenses_models/*": ["src/app/models/expenses/*"],
      "@finance_models/*": ["src/app/models/finance/*"],
      "@households_models/*": ["src/app/models/households/*"],
      "@incomes_models/*": ["src/app/models/incomes/*"],
      "@investments_models/*": ["src/app/models/investments/*"],
      "@savings_models/*": ["src/app/models/savings/*"],
      "@users_models/*": ["src/app/models/users/*"],
      "@const_models/*": ["src/app/core/const/*"],
      "@import_models/*": ["src/app/models/import/*"]
      
    }
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "strictTemplates": true,
    "enableExperimentalFeatures": true
  }
}
